# Copy to `.env` and adjust. Loaded automatically on startup (via python-dotenv).
# CLI flags (--transport / --host / --port / --log-level) override these.

# --- Backend -----------------------------------------------------------------
# Which retrieval backend to load: a dotted "module:callable" returning a
# SearchBackend (called with the server Config). Leave EMPTY to use the bundled
# in-memory SampleBackend (illustrative records only — for demos and tests).
#   BYTEASK_BACKEND=my_pkg.my_module:make_backend
BYTEASK_BACKEND=

# Where runtime logs (query log, document requests) are written.
BYTEASK_LOGS=logs

# --- Transport ---------------------------------------------------------------
# "stdio" (default, for local coding agents) or "http" (Streamable HTTP).
MCP_TRANSPORT=stdio

# Logging verbosity: DEBUG | INFO | WARNING | ERROR | CRITICAL.
# All logs go to stderr; stdout is reserved for the stdio JSON-RPC channel.
LOG_LEVEL=INFO

# --- Streamable HTTP settings (only used when MCP_TRANSPORT=http) -------------

# Bind address. Use 127.0.0.1 for local-only; 0.0.0.0 to expose on the network.
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=8000

# Stub bearer-token auth for the HTTP endpoint. Clients must send:
#     Authorization: Bearer <this value>
# Leave EMPTY to run without auth (dev only — the server logs a loud warning).
# Replace this shared-secret stub with real auth before exposing publicly.
MCP_HTTP_AUTH_TOKEN=

# DNS-rebinding protection: comma-separated public host(s) allowed in the Host
# header. Behind a reverse proxy this must include your public domain (loopback
# is always allowed). Set to "*" to disable host validation (trusted proxy only).
MCP_ALLOWED_HOSTS=
